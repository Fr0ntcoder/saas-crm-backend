generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
}

enum ClientStatus {
  ACTIVE
  CHURN_RISK @map("churn_risk")
  NEW
}

enum DealStage {
  NEW
  CONTACTED
  PROPOSAL
  WON
  LOST
}

enum DealSource {
  WEBSITE
  REFERRAL
  OUTBAND
  ADS
}

enum TaskStatus {
  TODO
  IN_PROGRESS @map("in_progress")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  password      String
  profile       Profile?
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id") @db.Uuid

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Company {
  id        String    @id @default(ulid()) @db.Uuid
  name      String
  ownerId   String    @map("owner_id") @db.Uuid
  profiles  Profile[]
  client    Client[]
  deals     Deal[]
  tasks     Task[]
  invoices  Invoice[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([ownerId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("companies")
}

model Profile {
  id        String   @id @db.Uuid
  fullName  String   @map("full_name")
  email     String
  role      Role
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String   @map("company_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique @map("user_id") @db.Uuid
  clients   Client[] @relation("ClientManager")
  deals     Deal[]   @relation("DealManager")
  tasks     Task[]   @relation("TaskManager")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([role])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("profiles")
}

model Client {
  id           String       @id @default(ulid()) @db.Uuid
  name         String
  industry     String
  contactEmail String       @map("contact_email")
  phone        String?
  status       ClientStatus
  monthlyValue Decimal      @map("monthly_value") @db.Decimal(12, 2)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId    String       @map("company_id") @db.Uuid
  manager      Profile      @relation("ClientManager", fields: [managerId], references: [id], onDelete: Restrict)
  managerId    String       @map("manager_id") @db.Uuid
  deals        Deal[]
  tasks        Task[]
  invoices     Invoice[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([managerId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("clients")
}

model Deal {
  id        String     @id @default(ulid()) @db.Uuid
  title     String
  stage     DealStage
  amount    Decimal    @db.Decimal(12, 2)
  source    DealSource
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String     @map("company_id") @db.Uuid
  manager   Profile    @relation("DealManager", fields: [managerId], references: [id], onDelete: Restrict)
  managerId String     @map("manager_id") @db.Uuid
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String     @map("client_id") @db.Uuid
  tasks     Task[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([managerId])
  @@index([clientId])
  @@index([stage])
  @@index([source])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("deals")
}

model Task {
  id        String       @id @default(ulid()) @db.Uuid
  title     String
  status    TaskStatus
  priority  TaskPriority
  dueDate   DateTime     @map("due_date")
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String       @map("company_id") @db.Uuid
  manager   Profile      @relation("TaskManager", fields: [managerId], references: [id], onDelete: Restrict)
  managerId String       @map("manager_id") @db.Uuid
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId  String?      @map("client_id") @db.Uuid
  deal      Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId    String?      @map("deal_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([managerId])
  @@index([clientId])
  @@index([dealId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("tasks")
}

model Invoice {
  id        String        @id @default(ulid()) @db.Uuid
  amount    Decimal       @db.Decimal(12, 2)
  status    InvoiceStatus
  dueDate   DateTime      @map("due_date")
  issuedAt  DateTime      @map("issued_at")
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String        @map("company_id") @db.Uuid
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String        @map("client_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([clientId])
  @@index([issuedAt])
  @@index([dueDate])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("invoices")
}
